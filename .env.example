# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key

# Clerk routes used by this app
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/library
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/library

# Neon Postgres — pooled connection (used at runtime by Prisma)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true

# Neon Postgres — direct connection (used by prisma migrate deploy during build)
DIRECT_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Google Gemini — AI generation pipeline (free tier at aistudio.google.com)
GEMINI_API_KEY=AIza...
